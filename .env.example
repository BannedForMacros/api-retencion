# ─── SQL Server (datamarket) ─────────────────────────────────────────────
DB_SERVER=localhost
DB_PORT=1433
DB_DATABASE=db_fsm_emmel
DB_DRIVER=ODBC Driver 18 for SQL Server

# Windows Authentication (true) o SQL Authentication (false).
# Si es true, DB_USER y DB_PASSWORD se ignoran.
DB_TRUSTED_CONNECTION=true

# Solo si DB_TRUSTED_CONNECTION=false:
DB_USER=
DB_PASSWORD=

# TLS (Driver 18 obliga TLS por defecto)
DB_ENCRYPT=yes
DB_TRUST_SERVER_CERTIFICATE=yes

# Timeouts (segundos)
DB_LOGIN_TIMEOUT=10
DB_QUERY_TIMEOUT=60

# ─── API ─────────────────────────────────────────────────────────────────
API_TITLE=Retenciones Datamarket API
API_VERSION=0.1.0

# CORS: "*" o lista separada por comas, ej. "http://localhost:3000,http://localhost:8000"
CORS_ORIGINS=*
